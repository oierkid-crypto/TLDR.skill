{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/startup-signal-radar/opportunity_card.schema.json",
  "title": "OpportunityCard",
  "type": "object",
  "required": [
    "opportunity_id",
    "title",
    "problem",
    "target_user",
    "ai_solution_hypothesis",
    "founder_fit",
    "distribution_fit",
    "business_model_fit",
    "evidence_summary",
    "scores",
    "decision"
  ],
  "properties": {
    "opportunity_id": { "type": "string" },
    "linked_cluster_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "title": { "type": "string" },
    "problem": {
      "type": "object",
      "required": ["statement", "workflow_context", "why_now"],
      "properties": {
        "statement": { "type": "string" },
        "workflow_context": { "type": "string" },
        "why_now": { "type": "string" }
      },
      "additionalProperties": false
    },
    "target_user": {
      "type": "object",
      "required": ["primary_segment", "search_behavior", "pain_trigger"],
      "properties": {
        "primary_segment": { "type": "string" },
        "search_behavior": { "type": "string" },
        "pain_trigger": { "type": "string" },
        "current_workarounds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ai_solution_hypothesis": {
      "type": "object",
      "required": ["product_shape", "ai_role", "mvp_scope"],
      "properties": {
        "product_shape": {
          "type": "string",
          "enum": ["saas", "agent", "workflow_tool", "api", "hybrid"]
        },
        "ai_role": { "type": "string" },
        "mvp_scope": { "type": "string" },
        "key_automation_loop": { "type": "string" }
      },
      "additionalProperties": false
    },
    "founder_fit": {
      "type": "object",
      "required": ["small_team_buildable", "ops_intensity", "notes"],
      "properties": {
        "small_team_buildable": { "type": "boolean" },
        "ops_intensity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "distribution_fit": {
      "type": "object",
      "required": ["seo_fit", "self_serve_fit", "distribution_notes"],
      "properties": {
        "seo_fit": { "type": "boolean" },
        "self_serve_fit": { "type": "boolean" },
        "distribution_notes": { "type": "string" },
        "suggested_entry_pages": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "business_model_fit": {
      "type": "object",
      "required": ["pricing_shape", "repeat_usage", "standardizable"],
      "properties": {
        "pricing_shape": { "type": "string" },
        "repeat_usage": { "type": "boolean" },
        "standardizable": { "type": "boolean" },
        "expansion_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "evidence_summary": {
      "type": "object",
      "required": ["platforms", "representative_quotes", "signal_summary"],
      "properties": {
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "representative_quotes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "signal_summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "scores": {
      "type": "object",
      "required": [
        "pain_score",
        "buildability_score",
        "ai_leverage_score",
        "distribution_fit_score",
        "business_quality_score",
        "overall_score"
      ],
      "properties": {
        "pain_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "buildability_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "ai_leverage_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "distribution_fit_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "business_quality_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "overall_score": { "type": "number", "minimum": 0, "maximum": 10 }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["status", "reason"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["watchlist", "research_next", "prototype_next", "reject"]
        },
        "reason": { "type": "string" },
        "immediate_next_step": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
