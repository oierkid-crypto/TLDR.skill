{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/startup-signal-radar/problem_cluster.schema.json",
  "title": "ProblemCluster",
  "type": "object",
  "required": [
    "cluster_id",
    "title",
    "summary",
    "primary_user_segments",
    "workflow",
    "pain_points",
    "evidence",
    "scores",
    "verdict"
  ],
  "properties": {
    "cluster_id": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "primary_user_segments": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "workflow": {
      "type": "object",
      "required": ["name", "category"],
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "repetition_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      },
      "additionalProperties": false
    },
    "pain_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "type"],
        "properties": {
          "description": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "time_cost",
              "money_cost",
              "quality_failure",
              "manual_repetition",
              "switching_cost",
              "support_failure",
              "complexity",
              "trust_failure",
              "other"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "additionalProperties": false
      }
    },
    "existing_solutions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failure_modes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "signals": {
      "type": "object",
      "properties": {
        "replacement_intent": { "type": "number", "minimum": 0, "maximum": 1 },
        "willingness_to_pay_hint": { "type": "number", "minimum": 0, "maximum": 1 },
        "cross_platform_support": { "type": "number", "minimum": 0, "maximum": 1 },
        "seo_intent_hint": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["platform", "url", "excerpt"],
        "properties": {
          "platform": {
            "type": "string",
            "enum": ["reddit", "x", "xiaohongshu", "other"]
          },
          "url": { "type": "string" },
          "excerpt": { "type": "string" },
          "user_segment_hint": { "type": "string" },
          "engagement": {
            "type": "object",
            "properties": {
              "likes": { "type": "number" },
              "comments": { "type": "number" },
              "shares": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "scores": {
      "type": "object",
      "required": [
        "pain_score",
        "buildability_score",
        "ai_leverage_score",
        "distribution_fit_score",
        "business_quality_score"
      ],
      "properties": {
        "pain_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "buildability_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "ai_leverage_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "distribution_fit_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "business_quality_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "verdict": {
      "type": "object",
      "required": ["priority", "reason"],
      "properties": {
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low", "reject"]
        },
        "reason": { "type": "string" },
        "next_action": {
          "type": "string",
          "enum": [
            "enter_watchlist",
            "deep_research",
            "founder_interview",
            "prototype",
            "ignore"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
